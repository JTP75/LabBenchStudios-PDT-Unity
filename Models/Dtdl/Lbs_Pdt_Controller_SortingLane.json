{
  "@id": "dtmi:LabBenchStudios:PDT:sortingLane;1",
  "@type": "Interface",
  "@context": [
    "dtmi:dtdl:context;3",
    "dtmi:dtdl:extension:quantitativeTypes;1"
  ],
  "displayName": "Sorting Lane",
  "extends": "dtmi:LabBenchStudios:PDT:iotModelContext;1",
  "contents": [
    { "@type": "Property", "name": "laneID",   "schema": "integer" },
    { "@type": "Property", "name": "laneName", "schema": "string"  },
    { "@type": "Property", "name": "laneCapacity",               "schema": "integer" },
    { "@type": "Property", "name": "overflowBuffer",             "schema": "integer" },
    { "@type": "Property", "name": "enableAutoDrain",            "schema": "boolean" },
    { "@type": "Property", "name": "drainIntervalSeconds",       "schema": "double"  },
    { "@type": "Property", "name": "drainIntervalJitterPct",     "schema": "double"  },
    { "@type": "Property", "name": "drainBatchMaxN",             "schema": "integer" },
    { "@type": "Property", "name": "expectedRegionCode",         "schema": "integer" },
    { "@type": "Property", "name": "fillAlertThresholdPct",      "schema": "double"  },
    { "@type": "Property", "name": "drainPackageCommandName",    "schema": "string"  },
    { "@type": "Property", "name": "enableIndicatorCommandName", "schema": "string"  },
    {
      "@type": "Telemetry",
      "name": "laneOccupancy",
      "displayName": "Lane Occupancy Count",
      "schema": "float"
    },
    {
      "@type": ["Telemetry", "Percent"],
      "name": "laneFillLevel",
      "displayName": "Lane Fill Level",
      "schema": "float",
      "unit": "percent"
    },
    {
      "@type": ["Telemetry", "TimeSpan"],
      "name": "laneOldestDwell",
      "displayName": "Oldest Package Dwell Time",
      "schema": "float",
      "unit": "second"
    },
    {
      "@type": "Telemetry",
      "name": "laneDrainRate",
      "displayName": "Drain Rate (packages/min)",
      "schema": "float"
    },
    {
      "@type": "Telemetry",
      "name": "laneAnomaly",
      "displayName": "Lane Anomaly Event",
      "schema": {
        "@type": "Object",
        "fields": [
          { "name": "packageId",  "schema": "string"  },
          { "name": "regionCode", "schema": "integer" },
          {
            "name": "reason",
            "schema": {
              "@type": "Enum",
              "valueSchema": "string",
              "enumValues": [
                { "name": "wrong_region", "displayName": "Wrong Region", "enumValue": "wrong_region" },
                { "name": "overflow",     "displayName": "Overflow",     "enumValue": "overflow"     }
              ]
            }
          }
        ]
      }
    },
    {
      "@type": "Command",
      "name": "enableIndicator",
      "request": {
        "name": "indicatorCommand",
        "displayName": "Indicator Light Command",
        "description": "COMMAND_ON (1) = alert, COMMAND_OFF (2) = normal. EDA auto-drives when fill crosses fillAlertThresholdPct.",
        "schema": "integer"
      },
      "response": {
        "name": "indicatorResponse",
        "schema": "float"
      }
    },
    {
      "@type": "Command",
      "name": "drainPackage",
      "request": {
        "name": "drainRequest",
        "displayName": "Manual Drain Request",
        "description": "COMMAND_ON (1). stateData: {\"packageId\":\"PKG-...\"}. EDA routes by typeID 13022 regardless of commandName.",
        "schema": {
          "@type": "Object",
          "fields": [
            { "name": "packageId", "schema": "string" }
          ]
        }
      },
      "response": {
        "name": "drainResponse",
        "displayName": "Drain Result",
        "description": "Success: {packageId, regionCode, dwellSeconds, result:\"drained\"}. Failure: statusCode=1 on envelope, stateData={packageId, result:\"NOT_FOUND\"}.",
        "schema": {
          "@type": "Object",
          "fields": [
            { "name": "packageId",    "schema": "string"  },
            { "name": "regionCode",   "schema": "integer" },
            { "name": "dwellSeconds", "schema": "float"   },
            { "name": "result",       "schema": "string"  }
          ]
        }
      }
    }
  ]
}
